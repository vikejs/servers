{
  "name": "vikejs-servers-workspace",
  "private": true,
  "version": "0.0.1",
  "description": "Server adapters for Vike",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "format": "biome format --write .",
    "lint": "biome lint .",
